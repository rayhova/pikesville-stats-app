{
  "name": "pikesville-stats-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "mobile:assets": "capacitor-assets generate --assetPath resources --android --ios --iconBackgroundColor '#101827' --splashBackgroundColor '#101827'",
    "mobile:sync": "cap sync",
    "mobile:sync:android": "cap sync android",
    "mobile:android:debug": "cd android && JAVA_HOME=/opt/homebrew/opt/openjdk@21 ./gradlew assembleDebug",
    "mobile:android:bundle": "cd android && JAVA_HOME=/opt/homebrew/opt/openjdk@21 ./gradlew bundleRelease",
    "mobile:open:android": "cap open android",
    "mobile:open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/app": "^7.1.2",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/ios": "^7.6.5",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.57.1",
    "@types/web-push": "^3.6.4",
    "next": "^15.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/node": "^22.18.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.3",
    "typescript": "^5.9.2"
  }
}
